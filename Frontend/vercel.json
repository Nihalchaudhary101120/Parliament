{
  "rewrites": [
    { "source": "/api/:path*",
     "destination": "https://parliamentbackend.onrender.com/:path*" 
    },
    {
      "source": "/(.*)",
      "destination": "/"
    },
    {
      "source": "/api/socket.io/:path*",
      "destination": "https://parliamentbackend.onrender.com/socket.io/:path*"
    }
  ]
}